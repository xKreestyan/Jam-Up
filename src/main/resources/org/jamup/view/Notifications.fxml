<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="780.0" prefWidth="960.0" style="-fx-background-color: #0d0d14;"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.jamup.view.NotificationsViewController">

    <!-- TOP NAVBAR -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="0.0"
              style="-fx-background-color: #12121c; -fx-border-color: #1e1e2e;
                     -fx-border-width: 0 0 1 0;">
            <padding>
                <Insets bottom="14.0" left="24.0" right="24.0" top="14.0"/>
            </padding>

            <!-- Logo -->
            <StackPane maxWidth="38.0" prefHeight="38.0" prefWidth="38.0"
                       style="-fx-background-color: #a855f7; -fx-background-radius: 10;">
                <Label style="-fx-font-size: 18px; -fx-text-fill: white;" text="♪"/>
            </StackPane>
            <Label style="-fx-font-size: 20px; -fx-font-weight: bold;
                          -fx-text-fill: white; -fx-font-family: 'Georgia';" text=" Jam Up"/>
            <Label style="-fx-font-size: 20px; -fx-font-weight: bold;
                          -fx-text-fill: #a855f7; -fx-font-family: 'Georgia';" text="!"/>

            <Region HBox.hgrow="ALWAYS"/>

            <!-- Back button -->
            <Button onAction="#onBackClick" text="← Back"
                    style="-fx-background-color: #1e1e2e; -fx-text-fill: white;
                           -fx-background-radius: 20; -fx-font-size: 13px;
                           -fx-cursor: hand; -fx-padding: 8 16 8 16;"/>

            <Region prefWidth="10.0"/>

            <!-- User menu -->
            <MenuButton fx:id="userMenuButton" text="👤"
                        style="-fx-background-color: #1e1e2e; -fx-text-fill: white;
                               -fx-background-radius: 20; -fx-font-size: 16px;
                               -fx-cursor: hand;">
                <items>
                    <MenuItem onAction="#onLogoutClick" text="Logout"/>
                </items>
            </MenuButton>
        </HBox>
    </top>

    <!-- CENTER CONTENT -->
    <center>
        <VBox spacing="0.0">
            <padding>
                <Insets bottom="28.0" left="32.0" right="32.0" top="28.0"/>
            </padding>

            <!-- Title row -->
            <HBox alignment="CENTER_LEFT">
                <VBox.margin><Insets bottom="20.0"/></VBox.margin>
                <Label style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: white;"
                       text="Notifications"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button onAction="#onMarkAllReadClick" text="Mark all as read"
                        style="-fx-background-color: transparent; -fx-text-fill: #a855f7;
                               -fx-font-size: 13px; -fx-cursor: hand;
                               -fx-border-color: #a855f7; -fx-border-radius: 20;
                               -fx-background-radius: 20; -fx-padding: 6 16 6 16;"/>
            </HBox>

            <!-- Notifications list -->
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                        style="-fx-background: transparent; -fx-background-color: transparent;
                               -fx-border-color: transparent;">
                <VBox fx:id="notificationsContainer" spacing="10.0">
                    <padding><Insets bottom="16.0"/></padding>
                    <Label fx:id="noNotificationsLabel"
                           text="No notifications yet"
                           style="-fx-text-fill: #666677; -fx-font-size: 13px;"
                           visible="false"/>
                </VBox>
            </ScrollPane>

        </VBox>
    </center>

</BorderPane>
